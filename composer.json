{
  "name": "perspeqtive/sulu-permission-aware-templates-bundle",
  "description": "Adds permissions to templates",
  "license": "proprietary",
  "type": "sulu-bundle",
  "authors": [
    {
      "name": "PERSPEQTIVE GmbH",
      "email": "mail@perspeqtive.de"
    }
  ],
  "keywords": [
    "sulu",
    "acl",
    "permissions",
    "template"
  ],
  "require": {
    "php": "^8.2",
    "sulu/sulu": "^2.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^12",
    "jackalope/jackalope-doctrine-dbal": "^1.3.4 || ^2.0",
    "php-cs-fixer/shim": "^3.75",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-symfony": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "PERSPEQTIVE\\SuluPermissionAwareTemplatesBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PERSPEQTIVE\\SuluPermissionAwareTemplatesBundle\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}